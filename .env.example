# MyRecSub - Environment Variables
# Copy this file to .env and fill in your values

# ─── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=127.0.0.1

# ─── Database (SQLite - auto-configured) ────────────────
# DATABASE_URL=file:~/.myrecsub/data.db

# ─── Gmail OAuth2 ──────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/gmail/callback

# ─── OpenAI (Optional - for AI invoice extraction) ─────
# Only used as fallback when rule-based extraction fails
# OPENAI_API_KEY=sk-...

# ─── Data Directories (auto-configured) ────────────────
# DATA_DIR=~/.myrecsub
# ATTACHMENTS_DIR=~/.myrecsub/attachments
# LOGS_DIR=~/.myrecsub/logs
