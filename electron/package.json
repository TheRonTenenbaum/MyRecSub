{
  "name": "myrecsub-electron",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "package": "electron-builder",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "get-port": "^5.1.1"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "com.myrecsub.app",
    "productName": "MyRecSub",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend"
      },
      {
        "from": "../frontend/out",
        "to": "frontend"
      },
      {
        "from": "../backend/prisma",
        "to": "prisma"
      },
      {
        "from": "../backend/node_modules/.prisma",
        "to": "prisma-engine"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "../resources/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "../resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["he", "en"]
    }
  }
}
